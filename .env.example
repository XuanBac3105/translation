# Telegram API credentials (lấy từ https://my.telegram.org)
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Groq API key (lay tu https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# ID hoặc username của group nguồn (group kín cần dịch)
# Có thể là số (VD: -1001234567890) hoặc username (VD: @groupname)
SOURCE_GROUP=

# ID hoặc username của group/channel mirror (nơi nhận bản dịch)
MIRROR_GROUP=

# Ngôn ngữ đích dịch sang (mặc định: vi = Tiếng Việt)
TARGET_LANG=vi

# Session string cho Railway (chạy generate_session.py để tạo)
# Chỉ cần khi deploy lên Railway, bỏ trống nếu chạy local
SESSION_STRING=
